{
  "name": "popthegrid",
  "private": true,
  "version": "0.11.2",
  "type": "module",
  "scripts": {
    "dev:client": "env-cmd -f .env.local -- vite -l warn",
    "dev:server": "env-cmd -f .env.local -- go run ./internal/cmd/dev",
    "dev": "run-p dev:*",
    "test": "vitest",
    "build:client": "vite build --mode production",
    "build:server": "go build -o popthegrid.out ./internal/cmd/popthegrid",
    "build": "env-cmd -f .env.production -- run-s build:client build:server",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/debug": "^4.1.12",
    "@types/human-date": "^1.4.5",
    "@types/node": "^25.5.0",
    "env-cmd": "^11.0.0",
    "njs-types": "^0.9.4",
    "npm-run-all": "^4.1.5",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@svelte-put/clickoutside": "^4.0.0",
    "@svelte-put/copy": "^4.0.0",
    "cookie": "^1.1.1",
    "debug": "^4.4.3",
    "human-date": "^1.4.0",
    "pretty-ms": "^9.3.0",
    "svelte-confetti": "^2.3.2",
    "svelte-material-icons": "^3.0.5"
  }
}
